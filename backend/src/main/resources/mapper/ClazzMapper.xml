<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.student.mapper.ClazzMapper">

    <select id="findAll" resultType="com.student.entity.Clazz">
        SELECT * FROM classes
    </select>
    
    <select id="findById" parameterType="int" resultType="com.student.entity.Clazz">
        SELECT * FROM classes WHERE id = #{id}
    </select>

</mapper>
